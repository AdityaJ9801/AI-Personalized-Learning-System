# ─────────────────────────────────────────────────────────────────
# EduAI Environment Configuration
# Copy this file to .env and fill in your values before running
# ─────────────────────────────────────────────────────────────────

# ── REQUIRED ──────────────────────────────────────────────────────
# Your OpenAI API key (get one at https://platform.openai.com)
OPENAI_API_KEY=sk-your-openai-api-key-here

# JWT signing secret — change this! Min 32 characters
SECRET_KEY=change-me-to-a-long-random-secret-key-32chars

# ── PostgreSQL (Docker) ────────────────────────────────────────────
POSTGRES_DB=eduai_db
POSTGRES_USER=eduai_user
POSTGRES_PASSWORD=eduai_secret_pass

# ── Redis (Docker) ─────────────────────────────────────────────────
REDIS_PASSWORD=redis_secret

# ── Flask ──────────────────────────────────────────────────────────
FLASK_ENV=development

# ── Optional: override DB URL for local dev (SQLite) ───────────────
# DATABASE_URL=sqlite:///eduai_dev.db
